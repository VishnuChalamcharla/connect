exports.handler = async (event) => {
    try {
        console.log("Full Event:", JSON.stringify(event));

        // 🔹 Step 1: Get Data from Contact Flow
        let data = event.Details.Parameters.Data;

        if (!data) {
            throw new Error("Missing Data from Contact Flow");
        }

        // 🔹 Step 2: If string, parse it
        if (typeof data === "string") {
            data = JSON.parse(data);
        }

        console.log("Parsed Data:", JSON.stringify(data));

        // 🔹 Step 3: Extract all queues
        const queues = [
            {
                name: "Gold",
                arn: data.GoldQueue.ResultData.attributes.ARN,
                percentage: data.GoldQueue.ResultData.attributes.percentage
            },
            {
                name: "VIP",
                arn: data.VIPQueue.ResultData.attributes.ARN,
                percentage: data.VIPQueue.ResultData.attributes.percentage
            },
            {
                name: "Platinum",
                arn: data.PlatinumQueue.ResultData.attributes.ARN,
                percentage: data.PlatinumQueue.ResultData.attributes.percentage
            }
        ];

        console.log("Queues:", JSON.stringify(queues));

        // 🔹 Step 4: Generate random number
        const random = Math.floor(Math.random() * 100) + 1;
        console.log("Random Number:", random);

        let cumulative = 0;
        let selectedQueue = null;

        // 🔹 Step 5: Apply percentage logic
        for (let q of queues) {

            let percent = parseInt(q.percentage);

            if (isNaN(percent)) {
                console.log(`Invalid percentage for ${q.name}`);
                continue;
            }

            cumulative += percent;

            console.log(`Checking ${q.name} → Range: 1-${cumulative}`);

            if (random <= cumulative) {
                selectedQueue = q;
                break;
            }
        }

        // 🔹 Step 6: Fallback (if needed)
        if (!selectedQueue) {
            console.log("No match found, using first queue as fallback");
            selectedQueue = queues[0];
        }

        console.log("Selected Queue:", selectedQueue);

        // 🔹 Step 7: Return to Connect
        return {
            queueArn: selectedQueue.arn,
            queueName: selectedQueue.name,
            randomNumber: random
        };

    } catch (error) {
        console.error("ERROR:", error);

        return {
            error: error.message || "Unknown error"
        };
    }
};
